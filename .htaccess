# PROTEKSI DATABASE & CONFIG
<FilesMatch "\.(sqlite|sqlite3|db|env|log|md|sh|py|json)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# PROTEKSI DIRECTORY LISTING
Options -Indexes

# PREVENT ACCESS TO HIDDEN FILES (.git, .htaccess, etc)
RedirectMatch 404 /\..*$

# DISABLE SERVER SIGNATURE
ServerSignature Off

# URL REWRITING ENGINE
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # FORCE HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Map pretty URLs to .php files
    # Example: /landing -> landing.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^([^\.]+)$ $1.php [NC,L]
</IfModule>

# SECURITY HEADERS (Fallback if not set by PHP)
<IfModule mod_headers.c>
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' unpkg.com fonts.googleapis.com; style-src 'self' 'unsafe-inline' unpkg.com fonts.googleapis.com; img-src 'self' data: https: tile.openstreetmap.org *.basemaps.cartocdn.com; font-src 'self' fonts.gstatic.com; connect-src 'self' https:;"
</IfModule>
