# Disable directory listing
Options -Indexes

# Protect sensitive files
<FilesMatch "\.(sqlite|json|log|php\.old|bak)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Allow access to index.php and other entry points (implicit)
# But strictly block config.json and database.sqlite
<Files "config.json">
    Require all denied
</Files>
<Files "database.sqlite">
    Require all denied
</Files>

# Protect .htaccess itself
<Files ".htaccess">
    Require all denied
</Files>
